# ── Required paths ────────────────────────────────────────────────────────────
# Read-only source directory — drop MP4 files here
NAS_MOUNT_PATH=/mnt/nas/soccer

# Writable output directory — finished reels written here
NAS_OUTPUT_PATH=/mnt/nas/soccer/output

# Local scratch space for in-progress jobs (~30 GB free needed per job)
WORKING_DIR=/tmp/soccer-pipeline

# Absolute path to directory containing model weight files (e.g. yolov8m.pt)
# On Linux/Mac: /path/to/models    On Windows (Docker Desktop): C:/path/to/models
MODEL_WEIGHTS_PATH=/mnt/nas/soccer/models

# ── Queue ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0
MAX_WORKERS=2

# ── Testing ───────────────────────────────────────────────────────────────────
# Set to true to bypass YOLO inference with a no-op detector (no model weights needed).
# For e2e infrastructure tests only — produces empty event logs, no real reels.
USE_NULL_DETECTOR=false

# ── GPU ──────────────────────────────────────────────────────────────────────
# Number of worker replicas (set to GPU count). Run 'make check-gpu' to verify.
GPU_COUNT=1
USE_GPU=true

# ── Detection ─────────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=/models/yolov8m.pt
YOLO_INFERENCE_SIZE=1280
DETECTION_FRAME_STEP=3
MIN_EVENT_CONFIDENCE=0.65
CHUNK_DURATION_SEC=30
CHUNK_OVERLAP_SEC=2.0

# ── Team config ──────────────────────────────────────────────────────────────
# Path to team/jersey config JSON (created by setup-team.sh).
# In Docker mode, this file is bind-mounted into the API container.
TEAM_CONFIG_PATH=~/.soccer-pipeline-team.json

# ── Clip padding ──────────────────────────────────────────────────────────────
PRE_EVENT_PAD_SEC=3.0
POST_EVENT_PAD_SEC=5.0

# ── Output encoding ───────────────────────────────────────────────────────────
OUTPUT_CODEC=copy
OUTPUT_CRF=18
OUTPUT_AUDIO_CODEC=copy

# ── NAS reliability ───────────────────────────────────────────────────────────
# Prevent macOS idle sleep while a pipeline job is running (uses caffeinate).
# Only applies on macOS (MPS mode). Ignored on Linux/Docker.
PREVENT_SLEEP=true
MAX_NAS_RETRY=3
NAS_RETRY_DELAY_SEC=5.0
WATCH_POLL_INTERVAL_SEC=10.0
WATCH_STABLE_TIME_SEC=30.0

# ── VLM Classification (Claude API) ─────────────────────────────────────────
# Use Claude vision to verify GK save events post-detection.
# Replaces heuristic jersey-color classification with visual analysis.
VLM_ENABLED=false
ANTHROPIC_API_KEY=              # Required when VLM_ENABLED=true
VLM_MODEL=claude-sonnet-4-20250514
VLM_FRAME_WIDTH=1280            # Resize width for extracted frames (smaller = cheaper)
VLM_MIN_CONFIDENCE=0.6          # Minimum VLM confidence to keep an event
VLM_RELAX_COLOR_MARGINS=false   # Relax BallTouchDetector thresholds when VLM is quality gate

# ── vLLM Video Tagging (Qwen3-VL) ────────────────────────────────────────────
# Chunk-based video tagging: splits video into 2.5-min chunks at 2 FPS,
# sends each to vLLM-hosted Qwen3-VL to tag goals, goal kicks, corners, saves.
# Requires vLLM server with: --max-model-len 90000 --kv-cache-dtype fp8
VLLM_ENABLED=false
VLLM_URL=http://10.10.2.222:8000
VLLM_MODEL=Qwen/Qwen3-VL-32B-Instruct
VLLM_MIN_CONFIDENCE=0.5         # Minimum confidence to keep a tagged event
VLLM_CHUNK_DURATION_SEC=150.0   # 2.5 min per chunk (300 frames at 2 FPS = 76K tokens)
VLLM_CHUNK_OVERLAP_SEC=15.0     # Overlap between chunks to catch boundary events
VLLM_CHUNK_FPS=2                # Frames per second for extracted chunks
# Legacy per-gap settings (used by RestartClassifier, kept for reference):
VLLM_CLIP_PRE_SEC=10.0
VLLM_CLIP_POST_SEC=20.0
